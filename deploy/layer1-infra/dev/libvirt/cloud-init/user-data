#cloud-config

users:
  - name: neo
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    plain_text_passwd: neo

ssh_pwauth: true

chpasswd:
  expire: false

package_update: true
packages:
  - curl
  - jq
  - socat
  - qemu-guest-agent

write_files:
  - path: /etc/netplan/60-provisioning.yaml
    permissions: '0600'
    content: |
      network:
        version: 2
        ethernets:
          ens4:
            dhcp4: false
            addresses:
              - 172.16.20.10/24
          ens5:
            dhcp4: false
            addresses:
              - 172.16.30.10/24

runcmd:
  - netplan apply

  # Wait for DNS to be ready after netplan apply
  - |
    for i in $(seq 1 30); do
      host get.k3s.io >/dev/null 2>&1 && break
      sleep 2
    done

  # Install k3s
  - curl -fL https://get.k3s.io | INSTALL_K3S_EXEC="--disable=traefik --write-kubeconfig-mode=644 --tls-san=0.0.0.0 --tls-san=172.16.30.10 --node-label=node.kubernetes.io/role=management" sh -

  # Wait for k3s
  - |
    for i in $(seq 1 120); do
      /usr/local/bin/kubectl get nodes 2>/dev/null | grep -q " Ready" && break
      sleep 5
    done

  # Generate external kubeconfig (accessible via baremetal network)
  - cp /etc/rancher/k3s/k3s.yaml /root/kubeconfig-external
  - sed -i "s|127.0.0.1:6443|172.16.30.10:6443|g" /root/kubeconfig-external
  - chmod 644 /root/kubeconfig-external

  # Signal readiness
  - touch /root/.mgmt-ready
