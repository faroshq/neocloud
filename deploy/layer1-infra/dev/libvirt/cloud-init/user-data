#cloud-config

users:
  - name: neo
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    plain_text_passwd: neo

ssh_pwauth: true

chpasswd:
  expire: false

package_update: true
packages:
  - curl
  - jq
  - socat
  - python3-pip
  - qemu-guest-agent

runcmd:
  # Configure provisioning network interface
  - |
    cat > /etc/netplan/60-provisioning.yaml <<'EOF'
    network:
      version: 2
      ethernets:
        enp2s0:
          addresses:
            - 172.16.20.10/24
    EOF
  - netplan apply

  # Install k3s
  - curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="--disable=traefik --write-kubeconfig-mode=644 --tls-san=0.0.0.0 --tls-san=172.16.30.1 --node-label=node-role.kubernetes.io/management=true" sh -

  # Wait for k3s
  - |
    for i in $(seq 1 120); do
      /usr/local/bin/kubectl get nodes 2>/dev/null | grep -q " Ready" && break
      sleep 5
    done

  # Generate external kubeconfig (accessible via baremetal network)
  - cp /etc/rancher/k3s/k3s.yaml /root/kubeconfig-external
  - sed -i "s|127.0.0.1:6443|172.16.30.1:6443|g" /root/kubeconfig-external
  - chmod 644 /root/kubeconfig-external

  # Signal readiness
  - touch /root/.mgmt-ready
